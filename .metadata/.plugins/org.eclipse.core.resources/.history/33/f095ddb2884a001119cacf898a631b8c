public record Product(String name, double price) { }

public class RecordExample {
    public static void main(String[] args) {
        Product p1 = new Product("Laptop", 1200.00);

        System.out.println(p1.name()); // "Laptop"
        System.out.println(p1.price()); // 1200.0

        System.out.println(p1); // Product[name=Laptop, price=1200.0]

        // 불변성 확인
        // p1.price = 999.0; // ❌ 컴파일 에러
    }
}