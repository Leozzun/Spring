<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean class="sample05.UserBean" id="userBean">
        <property name="id" value="user01"/>
        <property name="name" value="홍준화"/>
        <property name="addr" value="오리"/>
        <property name="phone" value="222-3333"/>
    </bean>
    
    <bean class="sample05.ProductBean" id="productBean">
        <property name="pno" value="1"/>
        <property name="pname" value="새우깡"/>
        <property name="price" value="4000"/>
    </bean>
    
    <bean class="sample05.OrderMessageImpl" id="orderMessage">
        <property name="orderId" value="10"/>
        <property name="message" value="주문하셨습니다."/>
        <property name="userBean" ref="userBean"/>
        <property name="productBean" ref="productBean"/>
    </bean>

</beans>
